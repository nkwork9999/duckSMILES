# name: test/sql/ducksmiles.test
# description: Test ducksmiles extension (SMILES + InChI)
# group: [ducksmiles]

require ducksmiles

# ============================================================================
# SMILES: mol_is_valid
# ============================================================================

query I
SELECT mol_is_valid('CCO');
----
true

query I
SELECT mol_is_valid('c1ccccc1');
----
true

query I
SELECT mol_is_valid('not_a_molecule');
----
false

query I
SELECT mol_is_valid('');
----
false

# ============================================================================
# SMILES: mol_formula
# ============================================================================

query I
SELECT mol_formula('O');
----
H2O

query I
SELECT mol_formula('CCO');
----
C2H6O

query I
SELECT mol_formula('c1ccccc1');
----
C6H6

query I
SELECT mol_formula('CC(=O)O');
----
C2H4O2

query I
SELECT mol_formula('[Na+].[Cl-]');
----
ClNa

# NULL on invalid
query I
SELECT mol_formula('invalid');
----
NULL

# ============================================================================
# SMILES: mol_num_atoms (heavy atoms)
# ============================================================================

query I
SELECT mol_num_atoms('CCO');
----
3

query I
SELECT mol_num_atoms('c1ccccc1');
----
6

query I
SELECT mol_num_atoms('invalid');
----
NULL

# ============================================================================
# SMILES: mol_num_bonds
# ============================================================================

query I
SELECT mol_num_bonds('CCO');
----
2

query I
SELECT mol_num_bonds('c1ccccc1');
----
6

query I
SELECT mol_num_bonds('invalid');
----
NULL

# ============================================================================
# SMILES: mol_weight
# ============================================================================

query I
SELECT round(mol_weight('O'), 2);
----
18.02

query I
SELECT round(mol_weight('CCO'), 2);
----
46.07

# ============================================================================
# InChI: inchi_is_valid
# ============================================================================

query I
SELECT inchi_is_valid('InChI=1S/C2H4O2/c1-2(3)4/h1H3,(H,3,4)');
----
true

query I
SELECT inchi_is_valid('not_an_inchi');
----
false

# ============================================================================
# InChI: inchi_is_standard
# ============================================================================

query I
SELECT inchi_is_standard('InChI=1S/C2H4O2/c1-2(3)4/h1H3,(H,3,4)');
----
true

# ============================================================================
# InChI: inchi_formula
# ============================================================================

query I
SELECT inchi_formula('InChI=1S/C2H4O2/c1-2(3)4/h1H3,(H,3,4)');
----
C2H4O2

query I
SELECT inchi_formula('InChI=1S/C6H12O6/c7-1-2-3(8)4(9)5(10)6(11)12-2/h2-11H,1H2');
----
C6H12O6

query I
SELECT inchi_formula('invalid');
----
NULL

# ============================================================================
# InChI: inchi_connections
# ============================================================================

query I
SELECT inchi_connections('InChI=1S/C2H4O2/c1-2(3)4/h1H3,(H,3,4)');
----
1-2(3)4

# ============================================================================
# InChI: inchi_has_stereo / inchi_num_stereo_centers
# ============================================================================

query I
SELECT inchi_has_stereo('InChI=1S/C2H4O2/c1-2(3)4/h1H3,(H,3,4)');
----
false

query I
SELECT inchi_has_stereo('InChI=1S/C19H28O2/c1-18-9-7-13(20)11-12(18)3-4-14-15-5-6-17(21)19(15,2)10-8-16(14)18/h11,14-17,21H,3-10H2,1-2H3/t14-,15-,16-,17-,18-,19-/m0/s1');
----
true

query I
SELECT inchi_num_stereo_centers('InChI=1S/C19H28O2/c1-18-9-7-13(20)11-12(18)3-4-14-15-5-6-17(21)19(15,2)10-8-16(14)18/h11,14-17,21H,3-10H2,1-2H3/t14-,15-,16-,17-,18-,19-/m0/s1');
----
6

query I
SELECT inchi_num_stereo_centers('InChI=1S/C2H4O2/c1-2(3)4/h1H3,(H,3,4)');
----
0

# ============================================================================
# InChIKey: inchikey_is_valid
# ============================================================================

query I
SELECT inchikey_is_valid('QTBSBXVTEAMEQO-UHFFFAOYSA-N');
----
true

query I
SELECT inchikey_is_valid('not-a-key');
----
false

# ============================================================================
# InChIKey: component extraction
# ============================================================================

query I
SELECT inchikey_connectivity('QTBSBXVTEAMEQO-UHFFFAOYSA-N');
----
QTBSBXVTEAMEQO

query I
SELECT inchikey_stereo('QTBSBXVTEAMEQO-UHFFFAOYSA-N');
----
UHFFFAOYSA

query I
SELECT inchikey_protonation('QTBSBXVTEAMEQO-UHFFFAOYSA-N');
----
N

# ============================================================================
# InChI: inchi_skeleton_match
# ============================================================================

query I
SELECT inchi_skeleton_match(
    'InChI=1S/C2H6O/c1-2-3/h3H,2H2,1H3',
    'InChI=1S/C2H6O/c1-2-3/h3H,2H2,1H3'
);
----
true

# ============================================================================
# SMILES: logp_crippen (Wildman-Crippen LogP)
# ============================================================================

# Methane: 1x C1 (0.1441) + 4x H1 (0.123) = 0.6361
query I
SELECT round(logp_crippen('C'), 4);
----
0.6361

# Water: 1x O2 (-0.2893) + 2x H2 (-0.2677) = -0.8247
query I
SELECT round(logp_crippen('O'), 4);
----
-0.8247

# Benzene: 6x C18 (0.1581) + 6x H1 (0.123) = 1.6866
query I
SELECT round(logp_crippen('c1ccccc1'), 4);
----
1.6866

# Ethanol (near zero, hydrophilic/lipophilic boundary)
query I
SELECT round(logp_crippen('CCO'), 4);
----
-0.0014

# Methanol
query I
SELECT round(logp_crippen('CO'), 4);
----
-0.3915

# Glucose: strongly hydrophilic
query I
SELECT logp_crippen('OCC1OC(O)C(O)C(O)C1O') < 0;
----
true

# Cholesterol: strongly lipophilic
query I
SELECT logp_crippen('CC(C)CCCC(C)C1CCC2C1(CCC3C2CC=C4C3(CCC(C4)O)C)C') > 3;
----
true

# NULL on invalid SMILES
query I
SELECT logp_crippen('not_a_molecule');
----
NULL

# NULL on empty string
query I
SELECT logp_crippen('');
----
NULL

# ============================================================================
# SMILES: Bemis-Murcko scaffolds and ring systems
# ============================================================================

query I
SELECT murcko_scaffold('Cc1ccccc1');
----
c1ccccc1

query I
SELECT murcko_scaffold('CC(=O)Oc1ccccc1C(=O)O');
----
c1ccccc1

query I
SELECT length(murcko_scaffold('CCCC'));
----
0

query I
SELECT generic_scaffold('c1ccccn1');
----
C1CCCCC1

query I
SELECT ring_systems_json('c1ccccc1');
----
[{"index":1,"num_atoms":6,"num_bonds":6,"num_rings":1,"aromatic":true,"atoms":[1,2,3,4,5,6],"bonds":[1,2,3,4,5,6],"rings":[{"index":1,"size":6,"aromatic":true,"atoms":[1,2,3,4,5,6],"bonds":[1,2,3,4,5,6]}]}]

query I
SELECT murcko_scaffold('not_a_molecule');
----
NULL

# ============================================================================
# SMILES/SMARTS: substructure match mappings
# ============================================================================

query I
SELECT mol_substructure_matches_json('CC(=O)O', 'C=O');
----
[{"match":1,"atom_indices":[2,3],"atoms":[{"query_atom":1,"target_atom":2,"symbol":"C"},{"query_atom":2,"target_atom":3,"symbol":"O"}]}]

query I
SELECT mol_substructure_matches_json('CCC', '[#6]~[#6]');
----
[{"match":1,"atom_indices":[1,2],"atoms":[{"query_atom":1,"target_atom":1,"symbol":"C"},{"query_atom":2,"target_atom":2,"symbol":"C"}]},{"match":2,"atom_indices":[2,3],"atoms":[{"query_atom":1,"target_atom":2,"symbol":"C"},{"query_atom":2,"target_atom":3,"symbol":"C"}]}]

query I
SELECT mol_substructure_matches_json('CCO', 'N');
----
[]

query I
SELECT mol_substructure_matches_json('not_a_molecule', 'C');
----
NULL

# ============================================================================
# SMILES: MolHash, standardization, MCS, and extended SMARTS predicates
# ============================================================================

query I
SELECT mol_hash('CC(=O)[O-].[Na+]', 'formula');
----
C2H3NaO2

query I
SELECT mol_hash('CC(=O)[O-].[Na+]', 'element_graph');
----
C(C)(O)O.[Na]

query I
SELECT mol_hash('CC(=O)[O-].[Na+]', 'anonymous_graph');
----
C.C(C)(C)C

query I
SELECT mol_hash('CCO', 'does_not_exist');
----
NULL

query I
SELECT mol_hash_methods();
----
["canonical_smiles","formula","net_charge","degree_vector","atom_bond_counts","element_graph","bond_order_graph","anonymous_graph","murcko_scaffold","generic_scaffold"]

query I
SELECT largest_fragment('CC(=O)[O-].[Na+]');
----
C(C)(=O)[O-]

query I
SELECT strip_salts('CCO.CN.[Cl-]');
----
C(C)O.CN

query I
SELECT neutralize_charges('CC(=O)[O-].[Na+]');
----
C(C)(=O)O.[Na+]

query I
SELECT fragment_parent('CC(=O)[O-].[Na+]');
----
C(C)(=O)O

query I
SELECT normalize_smiles('C1=CC=CC=C1');
----
c1ccccc1

query I
SELECT mol_has_substructure('[13CH4]', '[13C]');
----
true

query I
SELECT mol_has_substructure('[CH4:7]', '[C:7]');
----
true

query I
SELECT mol_has_substructure('F[C@H](Cl)Br', '[C@H]');
----
true

query I
SELECT mol_substructure_count('c1ccccc1', '[r6;x2]');
----
6

query I
SELECT mcs_smarts('CC(=O)O', 'CC(=O)N');
----
C(C)=O

query I
SELECT mcs_json('CC(=O)O', 'CC(=O)N');
----
{"num_atoms":3,"num_bonds":2,"smarts":"C(C)=O","atoms_a":[1,2,3],"atoms_b":[1,2,3],"atom_pairs":[{"a":1,"b":1},{"a":2,"b":2},{"a":3,"b":3}]}

query I
SELECT scaffold_network_json('Cc1ccccc1') LIKE '%"kind":"murcko_scaffold"%"smiles":"c1ccccc1"%';
----
true

# ============================================================================
# SMILES: add_hydrogens (return SMILES with explicit H atoms)
# ============================================================================

# Methane → output contains explicit [H] atoms
query I
SELECT add_hydrogens('C');
----
[C]([H])([H])([H])[H]

# Water
query I
SELECT add_hydrogens('O');
----
[O]([H])[H]

# Ethanol
query I
SELECT add_hydrogens('CCO');
----
[C]([C]([O][H])([H])[H])([H])([H])[H]

# Output is valid SMILES (round-trips through parser)
query I
SELECT mol_is_valid(add_hydrogens('CCO'));
----
true

query I
SELECT mol_is_valid(add_hydrogens('c1ccccc1'));
----
true

# Molecular formula is preserved through add_hydrogens
query I
SELECT mol_formula(add_hydrogens('CCO'));
----
C2H6O

query I
SELECT mol_formula(add_hydrogens('CC(=O)Oc1ccccc1C(=O)O'));
----
C9H8O4

# Idempotency: already-explicit H input produces same formula
query I
SELECT mol_formula(add_hydrogens(add_hydrogens('CCO')));
----
C2H6O

# Output contains [H] substrings
query I
SELECT add_hydrogens('CCO') LIKE '%[H]%';
----
true

# NULL on invalid SMILES
query I
SELECT add_hydrogens('not_a_molecule');
----
NULL

# NULL on empty string
query I
SELECT add_hydrogens('');
----
NULL

# ============================================================================
# MOL/SDF: structural JSON extraction
# ============================================================================

query I
WITH m AS (
    SELECT 'ethanol' || chr(10) || '  test' || chr(10) || chr(10) ||
           '  3  2  0  0  0  0  0  0  0  0999 V2000' || chr(10) ||
           '    0.0000    0.0000    0.0000 C   0  0  0  0  0' || chr(10) ||
           '    1.5400    0.0000    0.0000 C   0  0  0  0  0' || chr(10) ||
           '    2.3100    1.3300    0.0000 O   0  0  0  0  0' || chr(10) ||
           '  1  2  1  0' || chr(10) ||
           '  2  3  2  0' || chr(10) ||
           'M  END' || chr(10) AS mol
)
SELECT mol_block_atoms_json(mol) LIKE '%"index":3,"symbol":"O","x":2.31,"y":1.33,"z":0%'
FROM m;
----
true

query I
WITH m AS (
    SELECT 'ethanol' || chr(10) || '  test' || chr(10) || chr(10) ||
           '  3  2  0  0  0  0  0  0  0  0999 V2000' || chr(10) ||
           '    0.0000    0.0000    0.0000 C   0  0  0  0  0' || chr(10) ||
           '    1.5400    0.0000    0.0000 C   0  0  0  0  0' || chr(10) ||
           '    2.3100    1.3300    0.0000 O   0  0  0  0  0' || chr(10) ||
           '  1  2  1  0' || chr(10) ||
           '  2  3  2  0' || chr(10) ||
           'M  END' || chr(10) AS mol
)
SELECT mol_block_bonds_json(mol) LIKE '%"index":2,"atom1":2,"atom2":3,"bond_type":2%'
FROM m;
----
true

query I
WITH m AS (
    SELECT 'ethanol_v3000' || chr(10) || '  test' || chr(10) || chr(10) ||
           '  0  0  0     0  0            999 V3000' || chr(10) ||
           'M  V30 BEGIN CTAB' || chr(10) ||
           'M  V30 COUNTS 3 2 0 0 0' || chr(10) ||
           'M  V30 BEGIN ATOM' || chr(10) ||
           'M  V30 1 C 0.0000 0.0000 0.0000 0' || chr(10) ||
           'M  V30 2 C 1.5400 0.0000 0.0000 0 CFG=0' || chr(10) ||
           'M  V30 3 O 2.3100 1.3300 1.0000 0' || chr(10) ||
           'M  V30 END ATOM' || chr(10) ||
           'M  V30 BEGIN BOND' || chr(10) ||
           'M  V30 1 1 1 2 CFG=0' || chr(10) ||
           'M  V30 2 2 2 3' || chr(10) ||
           'M  V30 END BOND' || chr(10) ||
           'M  V30 END CTAB' || chr(10) ||
           'M  END' || chr(10) ||
           '> <ID>' || chr(10) || 'V3000-1' || chr(10) || chr(10) AS mol
)
SELECT mol_block_json(mol) LIKE '%"name":"ethanol_v3000"%"has_3d":true%"properties":[{"name":"ID","value":"V3000-1"}]%'
FROM m;
----
true

# ============================================================================
# MolMR + ring-count descriptors
# ============================================================================

# MolMR matches RDKit reference values
query I
SELECT abs(mol_mr('C') - 6.731) < 0.01;
----
true

query I
SELECT abs(mol_mr('c1ccccc1') - 26.442) < 0.05;
----
true

query I
SELECT mol_mr('not_a_molecule') IS NULL;
----
true

# Ring descriptors: benzene = 1 aromatic carbocycle
query IIII
SELECT num_aromatic_carbocycles('c1ccccc1'),
       num_aromatic_heterocycles('c1ccccc1'),
       num_aliphatic_rings('c1ccccc1'),
       num_saturated_rings('c1ccccc1');
----
1	0	0	0

# Pyridine = 1 aromatic heterocycle
query II
SELECT num_aromatic_heterocycles('c1ccncc1'), num_aromatic_carbocycles('c1ccncc1');
----
1	0

# Cyclohexane = saturated + aliphatic carbocycle
query III
SELECT num_saturated_carbocycles('C1CCCCC1'),
       num_aliphatic_carbocycles('C1CCCCC1'),
       num_saturated_rings('C1CCCCC1');
----
1	1	1

# Piperidine = saturated heterocycle
query II
SELECT num_saturated_heterocycles('C1CCNCC1'), num_aliphatic_heterocycles('C1CCNCC1');
----
1	1

# Acyclic molecule → all ring counts zero
query II
SELECT num_aliphatic_rings('CCO'), num_aromatic_carbocycles('CCO');
----
0	0
